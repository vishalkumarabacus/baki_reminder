datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               Int        @id @default(autoincrement())
  phone            String     @unique @db.VarChar(15)
  pin              String     @db.Text
  auth_token       String?    @db.VarChar(255)
  name             String?    @db.VarChar(255)
  business_name    String?    @db.VarChar(255)
  lang             String?    @default("en") @db.VarChar(10)
  reminder_template String?   @db.Text
  created_at       DateTime   @default(now()) @db.DateTime(0)
  customers        Customer[]
  entries          Entry[]

  @@map("users")
}

model Customer {
  id         String   @id @db.VarChar(50)
  user_id    Int
  name       String   @db.VarChar(255)
  phone      String   @db.VarChar(20)
  address    String?  @db.VarChar(255)
  notes      String?  @db.Text
  created_at DateTime @default(now()) @db.DateTime(0)

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  entries    Entry[]

  @@map("customers")
  @@index([user_id], name: "user_id")
}

model Entry {
  id          String   @id @db.VarChar(50)
  user_id     Int
  customer_id String   @db.VarChar(50)
  amount      Decimal  @db.Decimal(10, 2)
  type        EntryType
  due_date    DateTime? @db.Date
  status      EntryStatus @default(pending)
  note        String?   @db.Text
  created_at  DateTime  @default(now()) @db.DateTime(0)

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  customer    Customer  @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@map("entries")
  @@index([user_id], name: "user_id")
  @@index([customer_id], name: "customer_id")
}

enum EntryType {
  debit
  credit
}

enum EntryStatus {
  pending
  paid
}

model Notification {
  id          String   @id @db.VarChar(50)
  user_id     Int
  customer_id String   @db.VarChar(50)
  message     String   @db.Text
  created_at  DateTime @default(now()) @db.DateTime(0)

  @@map("notifications")
  @@index([user_id], name: "user_id")
}

